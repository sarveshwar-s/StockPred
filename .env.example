# Database Configuration
DB_HOST=your-database-host.rds.amazonaws.com
DB_USER=your-database-username
DB_PASSWORD=your-database-password
DB_NAME=trading

# API Keys
FINANCIAL_API_KEY=your-financial-modeling-prep-api-key
IEX_API_KEY=your-iex-cloud-api-key
NEWS_API_KEY=your-news-api-key
TWITTER_CONSUMER_KEY=your-twitter-consumer-key
TWITTER_CONSUMER_SECRET=your-twitter-consumer-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret

# Flask Configuration
SECRET_KEY=your-secret-key-for-session-management
PORT=5000

# Note: Copy this file to .env and fill in your actual values
# Never commit the .env file with real credentials to version control